@model ExamProctorPlatform.Models.User

@{
    ViewData["Title"] = "Register";
}

<div class="login-page">

    <div class="login-card shadow-lg">

        <div class="text-center mb-4">

            <div class="login-icon">
                <i class="bi bi-person-plus-fill"></i>
            </div>

            <h2 class="mt-3 fw-bold">
                Create Account
            </h2>

            <p class="text-muted">
                Register to access the ExamProctor Platform
            </p>

        </div>

        <form asp-action="Register" method="post">

            <div class="mb-3">

                <label class="form-label">
                    Full Name
                </label>

                <input asp-for="Name"
                       class="form-control form-control-lg"
                       placeholder="Enter your full name"
                       required />

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Email Address
                </label>

                <input asp-for="Email"
                       type="email"
                       class="form-control form-control-lg"
                       placeholder="Enter your email"
                       required />

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Password
                </label>

                <input asp-for="PasswordHash"
                       type="password"
                       class="form-control form-control-lg"
                       placeholder="Create a password"
                       required />

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Account Type
                </label>

                <select asp-for="Role"
                        id="roleSelect"
                        class="form-select form-select-lg">

                    <option value="Student">
                        Student
                    </option>

                    <option value="Admin">
                        Admin
                    </option>

                </select>

            </div>

            <!-- CDAC Percentage -->

            <div class="mb-4" id="percentageSection">

                <label class="form-label">
                    CDAC Percentage
                </label>

                <input type="number"
                       name="studentPercentage"
                       class="form-control form-control-lg"
                       placeholder="Enter your CDAC Percentage"
                       min="0"
                       max="100"
                       step="0.01" />

                <small class="text-muted">
                    Required only for Student accounts.
                </small>

            </div>

            <button class="btn btn-primary btn-lg w-100">

                <i class="bi bi-person-check-fill"></i>

                Create Account

            </button>

        </form>

        <hr />

        <div class="text-center">

            Already have an account?

            <a asp-action="Login"
               class="fw-semibold text-decoration-none">

                Login

            </a>

        </div>

    </div>

</div>

<script>

    const roleSelect = document.getElementById("roleSelect");

    const percentageSection =
        document.getElementById("percentageSection");

    function togglePercentageField() {

        if (roleSelect.value === "Student") {

            percentageSection.style.display = "block";

        }
        else {

            percentageSection.style.display = "none";

        }

    }

    togglePercentageField();

    roleSelect.addEventListener(
        "change",
        togglePercentageField
    );

</script>