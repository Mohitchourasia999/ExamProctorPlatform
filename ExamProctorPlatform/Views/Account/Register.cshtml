@model ExamProctorPlatform.Models.User
@{
    ViewData["Title"] = "Register identity";
}
<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-header bg-primary text-white text-center"><h3>Create New Account</h3></div>
            <div class="card-body">
                <form asp-action="Register" method="post">
                    <div class="mb-3"><label class="form-label">Full Name</label><input asp-for="Name" class="form-control" required /></div>
                    <div class="mb-3"><label class="form-label">Email Address</label><input asp-for="Email" type="email" class="form-control" required /></div>
                    <div class="mb-3"><label class="form-label">Password</label><input asp-for="PasswordHash" type="password" class="form-control" required /></div>
                    <div class="mb-3">
                        <label class="form-label">Register As (Select Role)</label>
                        <select asp-for="Role" id="role-select" class="form-select">
                            <option value="Student">Student (Exam Candidate)</option>
                            <option value="Admin">Admin (Professor / HR)</option>
                        </select>
                    </div>
                    <div class="mb-4" id="cdac-score-pane">
                        <label class="form-label fw-bold text-primary">Your C-DAC Graduation Aggregate Percentage</label>
                        <input type="number" step="0.01" name="studentPercentage" class="form-control" placeholder="e.g. 72.45" value="0" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Register Identity Profile</button>
                </form>
            </div>
        </div>
    </div>
</div>
<script>
    document.getElementById("role-select").addEventListener("change", function() {
        document.getElementById("cdac-score-pane").style.display = (this.value === "Admin") ? "none" : "block";
    });
</script>