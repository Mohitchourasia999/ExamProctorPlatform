@{
    ViewData["Title"] = "Validate Code";
}
<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow border-0">
            <div class="card-header bg-danger text-white text-center"><h5>Provide System Authorization Code</h5></div>
            <div class="card-body p-4">
                @if (ViewBag.Message != null)
                {
                    <div class="alert alert-info text-center small">@ViewBag.Message</div>
                }
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger text-center small">@ViewBag.Error</div>
                }
                <form asp-action="VerifyAndResetPassword" method="post">
                    <input type="hidden" name="email" value="@ViewBag.Email" />
                    <div class="mb-3"><label class="form-label">Verification OTP Code</label><input type="text" name="otp" class="form-control" required /></div>
                    <div class="mb-4"><label class="form-label">Define Fresh Account Password</label><input type="password" name="newPassword" class="form-control" required /></div>
                    <button type="submit" class="btn btn-dark w-100">Commit Credentials Overwrite</button>
                </form>
            </div>
        </div>
    </div>
</div>