@model ExamProctorPlatform.Models.CodingQuestion

@{
    ViewData["Title"] = "Coding Assessment";
}

<link rel="stylesheet" href="~/css/coding.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container-fluid coding-page py-4">

    <div class="row">

        <!-- LEFT PANEL -->

        <div class="col-lg-4">

            <div class="card shadow border-0 mb-4">

                <div class="card-header bg-primary text-white">

                    <h5 class="mb-0">

                        <i class="bi bi-file-earmark-code-fill"></i>

                        Problem Statement

                    </h5>

                </div>

                <div class="card-body">

                    <h4 class="fw-bold mb-3">

                        @Model.Title

                    </h4>

                    <div style="white-space:pre-line">

                        @Model.ProblemStatement

                    </div>

                </div>

            </div>

            <div class="card shadow border-0">

                <div class="card-header bg-dark text-white">

                    <i class="bi bi-camera-video-fill"></i>

                    AI Proctor

                </div>

                <div class="card-body text-center">

                    <video id="ai-webcam"
                           autoplay
                           playsinline
                           muted
                           class="w-100 rounded"
                           style="height:220px;object-fit:cover">
                    </video>

                    <div id="ai-status-badge"
                         class="alert alert-secondary mt-3 mb-0">

                        Initializing AI Monitoring...

                    </div>

                </div>

            </div>

        </div>

        <!-- RIGHT PANEL -->

        <div class="col-lg-8">

            <div class="card shadow border-0">

                <div class="card-header d-flex justify-content-between align-items-center">

                    <div>

                        <i class="bi bi-code-square"></i>

                        Code Editor

                    </div>

                    <span class="badge bg-primary">

                        C#

                    </span>

                </div>

                <div class="card-body p-0">

                    <div id="code-editor"
                         style="height:650px">

                        @Model.StarterCode

                    </div>

                </div>

                <div class="card-footer bg-white">

                    <div class="row align-items-center">

                        <div class="col-md-6">

                            <button class="btn btn-success"
                                    onclick="compileOnServer()">

                                <i class="bi bi-play-fill"></i>

                                Run Code

                            </button>

                            <button class="btn btn-primary ms-2"
                                    onclick="submitCode()">

                                <i class="bi bi-check-circle-fill"></i>

                                Submit

                            </button>

                        </div>

                        <div class="col-md-6">

                            <div id="console-output"
                                 class="alert alert-light mb-0 text-center">

                                Ready

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.23.0/ace.js"></script>

<script src="https://cdn.jsdelivr.net/npm/@@vladmandic/face-api/dist/face-api.js"></script>

<script>

    var editor = ace.edit("code-editor");

    editor.setTheme("ace/theme/github");

    editor.session.setMode("ace/mode/csharp");

    editor.setShowPrintMargin(false);

    editor.setOptions({

    fontSize:"16px",

    fontFamily:"Consolas",

    enableBasicAutocompletion:true,

    enableLiveAutocompletion:true

    });

    const videoNode=document.getElementById("ai-webcam");

    const aiStatusBadge=document.getElementById("ai-status-badge");

    navigator.mediaDevices.getUserMedia({

    video:true

    })

    .then(stream=>{

    videoNode.srcObject=stream;

    })

    .catch(()=>{

    alert("Camera access is required.");

    });
        videoNode.addEventListener("play",()=>{

    aiStatusBadge.className="alert alert-info";

    aiStatusBadge.innerHTML="<i class='bi bi-cpu'></i> Loading AI Models...";

    Promise.all([

    faceapi.nets.tinyFaceDetector.loadFromUri("https://cdn.jsdelivr.net/npm/@@vladmandic/face-api/model/")

    ])

    .then(()=>{

    aiStatusBadge.className="alert alert-success";

    aiStatusBadge.innerHTML="<i class='bi bi-shield-check'></i> AI Monitoring Active";

    setInterval(async()=>{

    const detections=

    await faceapi.detectAllFaces(

    videoNode,

    new faceapi.TinyFaceDetectorOptions()

    );

    if(detections.length===0){

    aiStatusBadge.className="alert alert-danger";

    aiStatusBadge.innerHTML="<i class='bi bi-person-x-fill'></i> Candidate Not Visible";

    }

    else if(detections.length>1){

    aiStatusBadge.className="alert alert-danger";

    aiStatusBadge.innerHTML="<i class='bi bi-people-fill'></i> Multiple Faces Detected";

    }

    else{

    aiStatusBadge.className="alert alert-success";

    aiStatusBadge.innerHTML="<i class='bi bi-person-check-fill'></i> Candidate Verified";

    }

    },1000);

    });

    });

    function compileOnServer(){

    const consoleBox=document.getElementById("console-output");

    consoleBox.className="alert alert-warning mb-0";

    consoleBox.innerHTML="<i class='bi bi-arrow-repeat'></i> Running Code...";

    fetch("/Coding/CompileCode",{

    method:"POST",

    headers:{

    "Content-Type":"application/x-www-form-urlencoded"

    },

    body:new URLSearchParams({

    userCode:editor.getValue()

    })

    })

    .then(res=>res.json())

    .then(data=>{

    if(data.success){

    consoleBox.className="alert alert-success mb-0";

    consoleBox.innerHTML="<i class='bi bi-check-circle-fill'></i> "+data.message;

    }

    else{

    consoleBox.className="alert alert-danger mb-0";

    consoleBox.innerHTML="<i class='bi bi-x-circle-fill'></i> "+data.message;

    }

    })

    .catch(()=>{

    consoleBox.className="alert alert-danger mb-0";

    consoleBox.innerHTML="<i class='bi bi-wifi-off'></i> Unable to connect to compiler service.";

    });

    }

        function submitCode() {

        const consoleBox = document.getElementById("console-output");

        consoleBox.className = "alert alert-info mb-0";

        consoleBox.innerHTML = "Submitting...";

        fetch("/Coding/SubmitCode", {

            method: "POST",

            headers: {
                "Content-Type": "application/x-www-form-urlencoded"
            },

            body: new URLSearchParams({
                userCode: editor.getValue()
            })

        })

        .then(res => res.json())

        .then(data => {

            if (data.success) {

                consoleBox.className = "alert alert-success mb-0";

            } else {

                consoleBox.className = "alert alert-danger mb-0";

            }

            consoleBox.innerHTML = data.message;

        })

        .catch(() => {

            consoleBox.className = "alert alert-danger mb-0";

            consoleBox.innerHTML = "Server connection failed.";

        });

    }

</script>