@{
    ViewData["Title"] = "Home";
}

<div class="hero-section">

    <div class="container">

        <div class="row align-items-center min-vh-100">

            <!-- Left Side -->

            <div class="col-lg-6">

                <span class="hero-badge">

                    <i class="bi bi-shield-check"></i>

                    AI Powered Examination Platform

                </span>

                <h1 class="hero-title mt-4">

                    Secure Online Exams

                    <span class="text-primary">
                        with AI Proctoring
                    </span>

                </h1>

                <p class="hero-description mt-4">

                    Conduct secure objective and coding examinations with
                    live AI monitoring, browser protection, automatic
                    evaluation and instant result generation.

                </p>

                <div class="row mt-5">

                    <div class="col-6 mb-3">

                        <div class="hero-feature">

                            <i class="bi bi-camera-video-fill text-primary"></i>

                            AI Face Detection

                        </div>

                    </div>

                    <div class="col-6 mb-3">

                        <div class="hero-feature">

                            <i class="bi bi-laptop text-primary"></i>

                            Coding Assessment

                        </div>

                    </div>

                    <div class="col-6 mb-3">

                        <div class="hero-feature">

                            <i class="bi bi-shield-lock-fill text-primary"></i>

                            Browser Security

                        </div>

                    </div>

                    <div class="col-6 mb-3">

                        <div class="hero-feature">

                            <i class="bi bi-graph-up-arrow text-primary"></i>

                            Instant Results

                        </div>

                    </div>

                </div>

                <div class="mt-5">

                    <div class="d-flex flex-wrap gap-4">

                        <div class="d-flex align-items-center">

                            <i class="bi bi-check-circle-fill text-success fs-4 me-2"></i>

                            <span class="fw-semibold">

                                AI Enabled Proctoring

                            </span>

                        </div>

                        <div class="d-flex align-items-center">

                            <i class="bi bi-check-circle-fill text-success fs-4 me-2"></i>

                            <span class="fw-semibold">

                                Secure Browser Environment

                            </span>

                        </div>

                        <div class="d-flex align-items-center">

                            <i class="bi bi-check-circle-fill text-success fs-4 me-2"></i>

                            <span class="fw-semibold">

                                Automatic MCQ Evaluation

                            </span>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Right Side -->

            <div class="col-lg-6">

                <div class="hero-image-card">

                    <div class="hero-card-header">

                        <div class="hero-dot bg-danger"></div>

                        <div class="hero-dot bg-warning"></div>

                        <div class="hero-dot bg-success"></div>

                    </div>

                    <div class="hero-card-body">

                        <div class="dashboard-box">

                            <i class="bi bi-camera-video-fill display-4 text-primary"></i>

                            <h5 class="mt-3">

                                AI Live Proctor

                            </h5>

                            <p class="text-muted">

                                Real-time candidate monitoring

                            </p>

                        </div>

                        <hr>

                        <div class="row text-center">

                            <div class="col-4">

                                <h3 class="text-primary fw-bold">

                                    99%

                                </h3>

                                <small>

                                    Accuracy

                                </small>

                            </div>

                            <div class="col-4">

                                <h3 class="text-success fw-bold">

                                    AI

                                </h3>

                                <small>

                                    Monitoring

                                </small>

                            </div>

                            <div class="col-4">

                                <h3 class="text-warning fw-bold">

                                    24x7

                                </h3>

                                <small>

                                    Security

                                </small>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>