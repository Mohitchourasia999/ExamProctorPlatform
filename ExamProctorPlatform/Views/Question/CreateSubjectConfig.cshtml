@model ExamProctorPlatform.Models.SubjectConfiguration

@{
    ViewData["Title"] = "Create Examination";
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold">
                <i class="bi bi-journal-plus text-primary"></i>
                Create Examination
            </h2>

            <p class="text-muted mb-0">
                Configure a new examination and add questions dynamically.
            </p>

        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
            Back
        </a>

    </div>

    <form id="googleFormEngine"
          asp-action="CreateSubjectConfig"
          method="post">

        <div class="card border-0 shadow mb-4">

            <div class="card-header bg-primary text-white">

                <i class="bi bi-sliders"></i>

                Examination Details

            </div>

            <div class="card-body">

                <div class="row">

                    <div class="col-md-8 mb-3">

                        <label class="form-label fw-semibold">
                            Subject Name
                        </label>

                        <input asp-for="SubjectName"
                               id="examSubjectName"
                               class="form-control form-control-lg"
                               placeholder="Java Programming"
                               required />

                    </div>

                    <div class="col-md-4 mb-3">

                        <label class="form-label fw-semibold">
                            Cutoff %
                        </label>

                        <input asp-for="CutoffPercentage"
                               class="form-control form-control-lg"
                               type="number"
                               step="0.01"
                               required />

                    </div>

                </div>

            </div>

        </div>

        <div id="questionsContainerArena"></div>

        <div class="text-center mt-4">

            <button type="button"
                    class="btn btn-outline-primary btn-lg"
                    onclick="addQuestionBlockNode()">

                <i class="bi bi-plus-circle-fill"></i>

                Add Question

            </button>

            <button type="submit"
                    class="btn btn-success btn-lg ms-2">

                <i class="bi bi-check-circle-fill"></i>

                Save Examination

            </button>

        </div>

    </form>

</div>

<script>

    let questionIndexCounter=0;

    function addQuestionBlockNode(){

    const index=questionIndexCounter++;

    const target=document.getElementById("questionsContainerArena");

    const card=document.createElement("div");

    card.className="card shadow border-0 mt-4";

    card.id=`question_block_${index}`;

    card.innerHTML=`

    <div class="card-header d-flex justify-content-between">

    <strong>

    <i class="bi bi-patch-question-fill"></i>

    Question ${index+1}

    </strong>

    <button

    type="button"

    class="btn btn-danger btn-sm"

    onclick="removeQuestionBlockNode(${index})">

    <i class="bi bi-trash"></i>

    Remove

    </button>

    </div>

    <div class="card-body">

    <div class="mb-3">

    <label class="form-label">

    Question

    </label>

    <textarea

    name="Questions[${index}].QuestionText"

    class="form-control"

    rows="2"

    required>

    </textarea>

    </div>

    <div class="row">

    <div class="col-md-6">

    <label>

    Question Type

    </label>

    <select

    name="Questions[${index}].QuestionType"

    class="form-select"

    onchange="toggleOptionPanelLayoutVisibility(this,${index})">

    <option value="Option">

    Multiple Choice

    </option>

    <option value="Written">

    Written

    </option>

    </select>

    </div>

    <div class="col-md-3">

    <label>

    Positive Marks

    </label>

    <input

    type="number"

    name="Questions[${index}].PositiveMarks"

    class="form-control"

    value="4">

    </div>

    <div class="col-md-3">

    <label>

    Negative Marks

    </label>

    <input

    type="number"

    name="Questions[${index}].NegativeMarks"

    class="form-control"

    value="-1">

    </div>

    </div>

    <div

    id="mcq_panel_index_${index}"

    class="mt-4">

        <input
    type="text"
    class="form-control mb-2 opt-val-${index}"
    placeholder="Option A"
    required>

    <input
    type="text"
    class="form-control mb-2 opt-val-${index}"
    placeholder="Option B"
    required>

    <input
    type="text"
    class="form-control mb-2 opt-val-${index}"
    placeholder="Option C"
    required>

    <input
    type="text"
    class="form-control mb-3 opt-val-${index}"
    placeholder="Option D"
    required>

    <input

    type="hidden"

    id="hidden_options_json_${index}"

    name="Questions[${index}].OptionsJson">

    </div>

    <label>

    Correct Answer

    </label>

    <input

    class="form-control"

    name="Questions[${index}].CorrectAnswer"

    required>

    </div>

    `;

    target.appendChild(card);

    }

    function removeQuestionBlockNode(id){

    const row=document.getElementById(`question_block_${id}`);

    if(row) row.remove();

    }

        function toggleOptionPanelLayoutVisibility(dropdown, index) {

        const panel = document.getElementById(`mcq_panel_index_${index}`);

        const inputs = panel.querySelectorAll(".opt-val-" + index);

        if (dropdown.value === "Written") {

            panel.style.display = "none";

            inputs.forEach(input => {

                input.required = false;
                input.value = "";

            });

        }
        else {

            panel.style.display = "block";

            inputs.forEach(input => {

                input.required = true;

            });

        }

    }

    document.getElementById("googleFormEngine").addEventListener("submit",function(){

    const subject=document.getElementById("examSubjectName").value;

    for(let i=0;i<questionIndexCounter;i++){

    const block=document.getElementById(`question_block_${i}`);

    if(!block) continue;

    const hidden=document.getElementById(`hidden_options_json_${i}`);

    const panel=document.getElementById(`mcq_panel_index_${i}`);

        if(panel.style.display !== "none"){

        let options=[];

        panel.querySelectorAll(`.opt-val-${i}`).forEach(x=>{

            if(x.value.trim()!="")
                options.push(x.value.trim());

        });

        hidden.value = JSON.stringify(options);

    }
    else{

        hidden.value = "";

    }

    const input=document.createElement("input");

    input.type="hidden";

    input.name=`Questions[${i}].Subject`;

    input.value=subject;

    block.appendChild(input);

    }

    });

</script>