@model ExamProctorPlatform.Models.Question

@{
    ViewData["Title"] = "Edit Question";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow border-0">

                <div class="card-header bg-warning">

                    <h3 class="mb-0">
                        <i class="bi bi-pencil-square"></i>
                        Edit Question
                    </h3>

                </div>

                <div class="card-body">

                    <form asp-action="EditQuestion" method="post">

                        <input asp-for="Id" type="hidden" />

                        <input asp-for="Subject" type="hidden" />

                        <div class="mb-4">

                            <label class="form-label fw-bold">
                                Question
                            </label>

                            <textarea asp-for="QuestionText"
                                      rows="3"
                                      class="form-control"></textarea>

                        </div>

                        <div class="mb-4">

                            <label class="form-label fw-bold">
                                Question Type
                            </label>

                            <select asp-for="QuestionType"
                                    class="form-select">

                                <option value="Option">
                                    Multiple Choice
                                </option>

                                <option value="Written">
                                    Written
                                </option>

                            </select>

                        </div>

                        <div class="mb-4">

                            <div class="d-flex justify-content-between align-items-center mb-2">

                                <label class="form-label fw-bold mb-0">

                                    Options

                                </label>

                                <button type="button"
                                        class="btn btn-sm btn-outline-primary"
                                        onclick="addOption()">

                                    <i class="bi bi-plus-circle"></i>

                                    Add Option

                                </button>

                            </div>

                            <div id="optionsContainer">
                            </div>

                        </div>

                        <input asp-for="OptionsJson"
                               id="OptionsJson"
                               type="hidden" />

                        <div class="mb-4">

                            <label class="form-label fw-bold">

                                Correct Answer

                            </label>

                            <select asp-for="CorrectAnswer"
                                    id="correctAnswer"
                                    class="form-select">

                                <option value="">
                                    Select Correct Answer
                                </option>

                            </select>

                        </div>

                        <div class="row">

                            <div class="col-md-6">

                                <label class="form-label fw-bold">

                                    Positive Marks

                                </label>

                                <input asp-for="PositiveMarks"
                                       class="form-control" />

                            </div>

                            <div class="col-md-6">

                                <label class="form-label fw-bold">

                                    Negative Marks

                                </label>

                                <input asp-for="NegativeMarks"
                                       class="form-control" />

                            </div>

                        </div>

                        <div class="mt-4 d-flex justify-content-between">

                            <a asp-action="ViewQuestions"
                               asp-route-subjectName="@Model.Subject"
                               class="btn btn-secondary">

                                <i class="bi bi-arrow-left"></i>

                                Back

                            </a>

                            <button class="btn btn-warning">

                                <i class="bi bi-check-circle-fill"></i>

                                Update Question

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

<script>

    let optionCount = 0;

    function addOption(value = "") {

        optionCount++;

        const container = document.getElementById("optionsContainer");

        const row = document.createElement("div");

        row.className = "input-group mb-2 option-row";

        row.innerHTML = `
            <input type="text"
                   class="form-control option-input"
                   placeholder="Option ${optionCount}"
                   value="${value}" />

            <button type="button"
                    class="btn btn-outline-danger"
                    onclick="removeOption(this)">

                <i class="bi bi-trash"></i>

            </button>
        `;

        container.appendChild(row);

        row.querySelector(".option-input")
            .addEventListener("input", refreshCorrectAnswerDropdown);

        refreshCorrectAnswerDropdown();
    }

    function removeOption(button) {

        button.parentElement.remove();

        refreshCorrectAnswerDropdown();

    }

    function refreshCorrectAnswerDropdown() {

        const dropdown = document.getElementById("correctAnswer");

        const selected = dropdown.value;

        dropdown.innerHTML =
            '<option value="">Select Correct Answer</option>';

        document.querySelectorAll(".option-input").forEach(input => {

            if (input.value.trim() !== "") {

                const option = document.createElement("option");

                option.value = input.value.trim();

                option.text = input.value.trim();

                dropdown.appendChild(option);

            }

        });

        dropdown.value = selected;
    }

    const existingOptions = JSON.parse('@Html.Raw(Model.OptionsJson ?? "[]")');

    if (Array.isArray(existingOptions) && existingOptions.length > 0) {

        existingOptions.forEach(option => addOption(option));

    }
    else {

        addOption();
        addOption();
        addOption();
        addOption();

    }

    refreshCorrectAnswerDropdown();

    document.getElementById("correctAnswer").value =
    '@Model.CorrectAnswer';

    document.querySelector("form").addEventListener("submit", function () {

        let options = [];

        document.querySelectorAll(".option-input").forEach(input => {

            if (input.value.trim() !== "") {

                options.push(input.value.trim());

            }

        });

        document.getElementById("OptionsJson").value =
            JSON.stringify(options);

    });

</script>