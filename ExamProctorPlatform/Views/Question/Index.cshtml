@model IEnumerable<ExamProctorPlatform.Models.SubjectConfiguration>
@{
    ViewData["Title"] = "Admin Control Suite";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Administrative Dashboard Terminal</h2>
        <a asp-action="CreateSubjectConfig" class="btn btn-primary">➕ Create New Examination</a>
    </div>
    <div class="card shadow">
        <div class="card-body p-0">
            <table class="table table-striped mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Subject Title Name</th>
                        <th>Required Cutoff Grade (%)</th>
                        <th class="text-center">Operations Options Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">No examination models active. Click 'Create New Examination' to deploy an assessment grid.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var subject in Model)
                        {
                            <tr>
                                <td><strong class="text-primary">@subject.SubjectName</strong></td>
                                <td><span class="badge bg-secondary">≥ @subject.CutoffPercentage %</span></td>
                                <td class="text-center">
                                    <a asp-action="SubjectResults" asp-route-subjectName="@subject.SubjectName" class="btn btn-sm btn-dark">View Scores Grid</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>