@model IEnumerable<ExamProctorPlatform.Models.ExamSession>

@{
    ViewData["Title"] = "Results Dashboard";

    var sortedSessions = Model
        .Where(s => s.Status != "Blocked_By_Violation")
        .OrderByDescending(s => s.Score)
        .Concat(Model.Where(s => s.Status == "Blocked_By_Violation"))
        .ToList();
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold">

                <i class="bi bi-bar-chart-fill text-primary"></i>

                @ViewBag.Subject Results

            </h2>

            <p class="text-muted mb-0">

                Performance overview of all candidates.

            </p>

        </div>

        <a asp-action="Index"
           class="btn btn-outline-secondary">

            <i class="bi bi-arrow-left"></i>

            Dashboard

        </a>

    </div>

    <div class="row mb-4">

        <div class="col-md-4">

            <div class="card border-0 shadow-sm">

                <div class="card-body text-center">

                    <i class="bi bi-people-fill display-4 text-primary"></i>

                    <h6 class="text-muted mt-3">

                        Total Candidates

                    </h6>

                    <h2>

                        @sortedSessions.Count

                    </h2>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card border-0 shadow-sm">

                <div class="card-body text-center">

                    <i class="bi bi-check-circle-fill display-4 text-success"></i>

                    <h6 class="text-muted mt-3">

                        Completed

                    </h6>

                    <h2>

                        @sortedSessions.Count(x => x.Status == "Completed")

                    </h2>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card border-0 shadow-sm">

                <div class="card-body text-center">

                    <i class="bi bi-shield-fill-x display-4 text-danger"></i>

                    <h6 class="text-muted mt-3">

                        Blocked

                    </h6>

                    <h2>

                        @sortedSessions.Count(x => x.Status == "Blocked_By_Violation")

                    </h2>

                </div>

            </div>

        </div>

    </div>

    <div class="card border-0 shadow">

        <div class="card-header bg-white">

            <div class="row">

                <div class="col-md-6">

                    <h5 class="mb-0 fw-bold">

                        <i class="bi bi-table"></i>

                        Student Results

                    </h5>

                </div>

                <div class="col-md-6">

                    <input id="searchBox"
                           class="form-control"
                           placeholder="Search Student ID..." />

                </div>

            </div>

        </div>

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">

                    <tr>

                        <th>Rank</th>

                        <th>Student ID</th>

                        <th>Violations</th>

                        <th>Status</th>

                        <th>Score</th>

                    </tr>

                </thead>

                <tbody id="resultTable">

                    @if (!sortedSessions.Any())
                    {
                        <tr>

                            <td colspan="5"
                                class="text-center py-5 text-muted">

                                <i class="bi bi-folder-x display-5"></i>

                                <br />

                                No Results Available

                            </td>

                        </tr>
                    }
                    else
                    {
                        int rank = 1;

                        foreach (var session in sortedSessions)
                        {
                            <tr>

                                <td>

                                    @rank

                                </td>

                                <td>

                                    @session.UserId

                                </td>

                                <td>

                                    @session.TabSwitches / 3

                                </td>

                                <td>

                                    @if (session.Status == "Completed")
                                    {
                                        <span class="badge bg-success">

                                            Completed

                                        </span>
                                    }
                                    else if (session.Status == "Blocked_By_Violation")
                                    {
                                        <span class="badge bg-danger">

                                            Blocked

                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">

                                            Active

                                        </span>
                                    }

                                </td>

                                <td>

                                    @if (session.Status == "Blocked_By_Violation")
                                    {
                                        <span class="text-danger fw-bold">

                                            @session.Score

                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-success fw-bold">

                                            @session.Score

                                        </span>
                                    }

                                </td>

                            </tr>

                            rank++;
                        }
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

<script>

    document.getElementById("searchBox").addEventListener("keyup",function(){

    let value=this.value.toLowerCase();

    let rows=document.querySelectorAll("#resultTable tr");

    rows.forEach(function(row){

    row.style.display=row.innerText.toLowerCase().includes(value)?"":"none";

    });

    });

</script>