@model IEnumerable<ExamProctorPlatform.Models.Question>

@{
    ViewData["Title"] = "Question Bank";
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold">
                <i class="bi bi-list-check text-primary"></i>
                @ViewBag.Subject Question Bank
            </h2>

            <p class="text-muted mb-0">
                Manage questions for this examination.
            </p>

        </div>

        <div>

            <a asp-action="CreateQuestion"
               asp-route-subjectName="@ViewBag.Subject"
               class="btn btn-success me-2">

                <i class="bi bi-plus-circle-fill"></i>
                Add Question

            </a>

            <a asp-action="Index"
               class="btn btn-outline-secondary">

                <i class="bi bi-arrow-left"></i>
                Back

            </a>

        </div>

    </div>

    <div class="card shadow border-0">

        <div class="card-header bg-white">

            <div class="row">

                <div class="col-md-6">

                    <h5 class="mb-0">

                        <i class="bi bi-patch-question-fill"></i>

                        Questions

                    </h5>

                </div>

                <div class="col-md-6">

                    <input id="searchBox"
                           class="form-control"
                           placeholder="Search question..." />

                </div>

            </div>

        </div>

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">

                    <tr>

                        <th>#</th>

                        <th>Question</th>

                        <th>Type</th>

                        <th>Marks</th>

                        <th width="220">
                            Actions
                        </th>

                    </tr>

                </thead>

                <tbody id="questionTable">

                    @if (!Model.Any())
                    {
                        <tr>

                            <td colspan="5"
                                class="text-center py-5 text-muted">

                                <i class="bi bi-folder-x display-5"></i>

                                <br /><br />

                                No questions available.

                            </td>

                        </tr>
                    }
                    else
                    {
                        int count = 1;

                        foreach (var q in Model)
                        {
                            <tr>

                                <td>

                                    @count

                                </td>

                                <td>

                                    @q.QuestionText

                                </td>

                                <td>

                                    <span class="badge bg-info">

                                        @q.QuestionType

                                    </span>

                                </td>

                                <td>

                                    +@q.PositiveMarks / @q.NegativeMarks

                                </td>

                                <td>

                                    <a asp-action="EditQuestion"
                                       asp-route-id="@q.Id"
                                       class="btn btn-outline-warning btn-sm me-1">

                                        <i class="bi bi-pencil-square"></i>

                                        Edit

                                    </a>

                                    <a asp-action="DeleteQuestion"
                                       asp-route-id="@q.Id"
                                       onclick="return confirm('Delete this question?');"
                                       class="btn btn-outline-danger btn-sm">

                                        <i class="bi bi-trash"></i>

                                        Delete

                                    </a>

                                </td>

                            </tr>

                            count++;
                        }
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

<script>

    document.getElementById("searchBox").addEventListener("keyup", function () {

        let value = this.value.toLowerCase();

        let rows = document.querySelectorAll("#questionTable tr");

        rows.forEach(function (row) {

            row.style.display =
                row.innerText.toLowerCase().includes(value)
                ? ""
                : "none";

        });

    });

</script>