@model IEnumerable<ExamProctorPlatform.Models.SubjectConfiguration>
@{
    ViewData["Title"] = "Student Grid Dashboard";
}

<div class="container mt-5">
    <div class="p-3 bg-white shadow-sm rounded border-start border-success border-4 mb-4">
        <h2 class="text-secondary mb-0">Student Assessment Gateway</h2>
        <small class="text-muted font-monospace">Authorized Session Validation Active</small>
    </div>
    <div class="row">
        @if (Model == null || !Model.Any())
        {
            <div class="col-12 text-center text-muted p-5 bg-white rounded border border-light-subtle shadow-sm">
                You are currently ineligible for any active testing cycles or no tracks match your CDAC profile parameters scores.
            </div>
        }
        else
        {
            foreach (var subject in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100 text-center border-0 bg-white rounded-3 overflow-hidden">
                        <div class="card-body p-4">
                            <div class="fs-1 mb-2">📄</div>
                            <h4 class="fw-bold text-dark mb-4">@subject.SubjectName</h4>
                            <button class="btn btn-success w-100 py-2 fw-bold" onclick="launchExamPopup('@Url.Action("VerifyExamAccess", "Student", new { subject = subject.SubjectName })')">🚀 Launch Secure Exam Window</button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<script>
    function launchExamPopup(url) {
        const width = window.screen.availWidth;
        const height = window.screen.availHeight;
        const popupOptions = `width=${width},height=${height},top=0,left=0,fullscreen=yes,directories=no,titlebar=no,toolbar=no,location=no,status=no,menubar=no,scrollbars=yes,resizable=no`;

        const examWindow = window.open(url, "SecureExamPlatformWindow", popupOptions);
        if (!examWindow) {
            alert("🔒 Workspace initialization halted: Please allow window popups from browser toolbar configurations to launch the test frame.");
        }
        else {
            const loopTimer = setInterval(() => {
                if (examWindow.closed) {
                    clearInterval(loopTimer);
                    window.location.reload();
                }
                else {
                    examWindow.focus();
                }
            }, 400);
        }
    }
</script>