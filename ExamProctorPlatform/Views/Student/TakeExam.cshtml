@model IEnumerable<ExamProctorPlatform.Models.Question>

@{
    ViewData["Title"] = "Secure Examination";
    Layout = null;
}

<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>SandBox | Secure Examination</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet"
          href="~/css/exam.css"
          asp-append-version="true" />

</head>

<body class="exam-body"
      style="user-select:none;
             -webkit-user-select:none;
             overflow:hidden;"
      oncontextmenu="return false;">

    <input type="hidden"
           id="exam-session-id"
           value="@ViewBag.SessionId" />

    <div class="progress exam-progress">

        <div class="progress-bar"
             id="progressBar"
             style="width:0%">
        </div>

    </div>

    <div class="container-fluid vh-100 d-flex flex-column p-0">

        <!-- HEADER -->

        <div class="exam-header">

            <div>

                <h3 class="fw-bold mb-2">

                    <i class="bi bi-journal-bookmark-fill"></i>

                    @ViewBag.Subject Assessment

                </h3>

                <div class="text-muted">

                    <i class="bi bi-person-circle"></i>

                    Candidate

                    @User.Identity?.Name

                </div>

            </div>

            <div class="timer-box">

                <i class="bi bi-clock-fill"></i>

                <span id="timer">
                    30:00
                </span>

            </div>

        </div>

        <div class="d-flex flex-grow-1 overflow-hidden">

            <!-- QUESTIONS -->

            <div class="flex-grow-1 overflow-auto p-4">

                <form id="examForm"
                      asp-action="SubmitExam"
                      method="post"
                      onsubmit="handleFormSubmit(event)">

                    <input type="hidden"
                           name="sessionId"
                           value="@ViewBag.SessionId" />

                    @{
                        int questionNumber = 1;
                    }

                    @foreach (var q in Model)
                    {

                        <div class="question-card">

                            <div class="question-header">

                                <strong>

                                    <i class="bi bi-patch-question-fill"></i>

                                    Question @questionNumber

                                </strong>

                                <span class="badge bg-info">

                                    +@q.PositiveMarks

                                    &nbsp;

                                    <i class="bi bi-dash-circle-fill text-warning"></i>

                                    -@q.NegativeMarks

                                </span>

                            </div>

                            <div class="question-body">

                                <!-- THIS WAS MISSING -->

                                <p class="question-title fw-semibold mb-3">

                                    @q.QuestionText

                                </p>

                                <div class="options-container">
                                    @if (q.QuestionType == "Option")
                                    {
                                        @if (q.Options != null && q.Options.Any())
                                        {
                                            @foreach (var option in q.Options)
                                            {
                                                <div class="option-card"
                                                     onclick="selectOption(this)">

                                                    <input type="radio"
                                                           class="form-check-input ms-1"
                                                           name="question_@q.Id"
                                                           value="@option" />

                                                    <label class="form-check-label ms-3 text-dark fw-medium">
                                                        @option
                                                    </label>

                                                </div>
                                            }

                                            <button type="button"
                                                    class="btn btn-outline-primary btn-sm mt-2 font-monospace"
                                                    onclick="clearSelection('question_@q.Id')">

                                                🧹 Clear Option Selection

                                            </button>
                                        }
                                        else
                                        {
                                            <div class="alert alert-warning mb-0">

                                                No options found for this question.

                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <textarea class="form-control anti-paste-field"
                                          name="question_@q.Id"
                                          rows="4"
                                          placeholder="Type your answer here..."></textarea>
                                    }

                                </div>

                            </div>

                        </div>

                        questionNumber++;
                    }

                    <div class="text-center my-5">

                        <button type="submit"
                                class="btn btn-primary btn-lg submit-btn px-5 py-3 shadow fw-bold">

                            <i class="bi bi-check-circle-fill"></i>

                            Submit Assessment

                        </button>

                    </div>

                </form>

            </div>

            <!-- PROCTOR PANEL -->

            <div class="proctor-sidebar"
                 style="width:280px;">

                <div class="card border-0 shadow-sm">

                    <div class="card-header bg-dark text-white text-center fw-bold">

                        <i class="bi bi-camera-video-fill"></i>

                        Live AI Proctor

                    </div>

                    <div class="card-body bg-light text-center p-2">

                        <div class="bg-black rounded border border-2 border-danger overflow-hidden mb-2"
                             style="height:180px;position:relative;">

                            <video id="proctor-webcam"
                                   autoplay
                                   muted
                                   playsinline
                                   class="w-100 h-100"
                                   style="object-fit:cover;">
                            </video>

                            <div class="badge bg-danger"
                                 style="position:absolute;bottom:5px;left:5px;font-size:10px;">

                                LIVE

                            </div>

                        </div>

                        <ul class="list-group list-group-flush">

                            <li class="list-group-item">
                                🟢 Camera Connected
                            </li>

                            <li class="list-group-item">
                                🟢 Screen Monitoring
                            </li>

                            <li class="list-group-item">
                                🟢 Clipboard Protected
                            </li>

                            <li class="list-group-item">
                                🟢 Anti Cheat Active
                            </li>

                        </ul>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <script>
        let seconds = 1800;

        setInterval(() => {

            let m = Math.floor(seconds / 60);
            let s = seconds % 60;

            document.getElementById("timer").innerHTML =
                `${m}:${s < 10 ? "0" : ""}${s}`;

            if (seconds > 0)
                seconds--;

        }, 1000);

        const sessionId =
            document.getElementById("exam-session-id").value;

        let isSubmitting = false;

        function clearSelection(radioName) {

            document.querySelectorAll(`input[name='${radioName}']`)
                .forEach(radio => radio.checked = false);

        }

        function selectOption(card) {

            const parent = card.parentElement;

            parent.querySelectorAll(".option-card")
                .forEach(x => x.classList.remove("selected-option"));

            card.classList.add("selected-option");

            card.querySelector("input").checked = true;

        }

        function syncViolation(type) {

            if (isSubmitting)
                return;

            fetch(`/api/proctor/log-violation?type=${type}&sessionId=${sessionId}`,
                {
                    method: "POST"
                })
                .then(r => r.json())
                .then(data => {

                    if (data.status === "Blocked_By_Violation") {

                        isSubmitting = true;

                        window.location.href = "/Student/Terminated";

                    }

                });

        }

        window.addEventListener("DOMContentLoaded", () => {

            enforceWindowCage();

            if (navigator.mediaDevices &&
                navigator.mediaDevices.getUserMedia) {

                navigator.mediaDevices.getUserMedia({

                    video: true

                })

                .then(stream => {

                    document.getElementById("proctor-webcam").srcObject =
                        stream;

                })

                .catch(() => {

                    alert("Camera permission is mandatory.");

                    window.close();

                });

            }

        });

        function enforceWindowCage() {

            if (isSubmitting)
                return;

            window.moveTo(0, 0);

            window.resizeTo(
                window.screen.availWidth,
                window.screen.availHeight
            );

        }

        window.addEventListener("resize", () => {

            if (!isSubmitting) {

                syncViolation("TabSwitch");

                enforceWindowCage();

            }

        });

        window.addEventListener("blur", () => {

            syncViolation("TabSwitch");

        });

        document.addEventListener("visibilitychange", () => {

            if (document.hidden) {

                syncViolation("TabSwitch");

            }

        });

        setInterval(() => {

            if ((window.screenX > 0 || window.screenY > 0)
                && !isSubmitting) {

                syncViolation("TabSwitch");

                enforceWindowCage();

            }

        }, 500);

        document.addEventListener("copy",
            e => e.preventDefault());

        document.querySelectorAll(".anti-paste-field")
            .forEach(field => {

                field.addEventListener("paste",
                    e => e.preventDefault());

            });

                        function handleFormSubmit(event) {

            event.preventDefault();

            isSubmitting = true;

            const form = document.getElementById("examForm");

            const formData = new FormData(form);

            document.getElementById("progressBar").style.width = "100%";

            fetch(form.action, {

                method: "POST",

                body: formData

            })

            .then(response => response.json())

            .then(data => {

                if (data.success) {

                    alert("Exam submitted successfully.");

                    window.location.href = "/Student";

                }
                else {

                    alert("Unable to submit exam.");

                    isSubmitting = false;

                }

            })

            .catch(() => {

                alert("Network error while submitting.");

                isSubmitting = false;

            });

        }

    </script>

</body>

</html>