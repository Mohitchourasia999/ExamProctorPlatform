@model IEnumerable<ExamProctorPlatform.Models.Question>

@{
    ViewData["Title"] = "Secure Examination Window Framework";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/exam.css" asp-append-version="true" />

    <title>

        ExamProctor | Secure Examination

    </title>
</head>
<body class="exam-body" style="user-select: none; -webkit-user-select: none; overflow: hidden;" oncontextmenu="return false;">

    <input type="hidden" id="exam-session-id" value="@ViewBag.SessionId" />

    <div class="progress exam-progress">

        <div class="progress-bar"
             style="width:0%"
             id="progressBar">
        </div>

    </div>

    <div class="container-fluid vh-100 d-flex flex-column p-0" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0;">

        <div class="exam-header">

            <div>

                <h3 class="mb-2 fw-bold">
                    <i class="bi bi-journal-bookmark-fill"></i>

                    @ViewBag.Subject Assessment
                </h3>

                <div class="text-muted">

                    <i class="bi bi-person-circle"></i>

                    <i class="bi bi-person-badge-fill"></i>

                    Candidate
                    @User.Identity?.Name

                </div>

            </div>

            <div class="d-flex align-items-center gap-3">

                <div class="timer-box">

                    <i class="bi bi-clock-fill"></i>

                    <span id="timer">
                        30:00
                    </span>

                </div>

            </div>

        </div>

        <div class="d-flex flex-grow-1 overflow-hidden w-100">

            <div class="flex-grow-1 overflow-auto p-4" style="height: 100%;">
                <form id="examForm" asp-action="SubmitExam" method="post" onsubmit="handleFormSubmit(event)">
                    <input type="hidden" name="sessionId" value="@ViewBag.SessionId" />

                    @foreach (var q in Model)
                    {
                        <div class="question-card">
                            <div class="question-header">
                                <span>
                                    <strong>
                                        <i class="bi bi-patch-question-fill"></i>
                                        Question @(Model.ToList().IndexOf(q) + 1)
                                    </strong>
                                </span>
                                <span class="badge bg-info">
                                    <i class="bi bi-award-fill"></i>

                                    +@q.PositiveMarks

                                    &nbsp;

                                    <i class="bi bi-dash-circle-fill text-warning"></i>

                                    -@q.NegativeMarks
                                </span>
                            </div>
                            <div class="question-body">
                                <p class="question-title">

                                <div class="options-container">
                                    @if (q.QuestionType == "Option" && q.Options != null && q.Options.Any())
                                    {
                                        @foreach (var option in q.Options)
                                        {
                                                <div class="option-card" onclick="selectOption(this)">
                                                <input class="form-check-input ms-1" type="radio" name="question_@q.Id" value="@option">
                                                <label class="form-check-label ms-3 text-dark fw-medium">@option</label>
                                            </div>
                                        }
                                            <button type="button" class="btn btn-outline-primary btn-sm mt-2 font-monospace" onclick="clearSelection('question_@q.Id')">🧹 Clear Option Selection</button>
                                    }
                                    else
                                    {
                                            <textarea name="question_@q.Id" class="form-control anti-paste-field" rows="3" placeholder="Type your answer here..."></textarea>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <div class="text-center my-5">
                        <button type="submit" class="btn btn-primary btn-lg submit-btn px-5 py-3 shadow fw-bold">
                            <i class="bi bi-check-circle-fill"></i>

                            Submit Assessment
                        </button>
                    </div>
                </form>
            </div>

            <div class="proctor-sidebar" style="width: 280px; height: 100%;">
                <div class="card border-0 shadow-sm w-100">
                    <div class="card-header bg-dark text-white text-center fw-bold py-2 small">
                        <i class="bi bi-camera-video-fill"></i>

                        Live AI Proctor
                    </div>
                    <div class="card-body p-2 text-center bg-light">
                        <div class="bg-black rounded border border-2 border-danger overflow-hidden mb-2" style="height: 180px; position: relative;">
                            <video id="proctor-webcam" autoplay playsinline muted class="w-100 h-100" style="object-fit: cover;"></video>
                            <div class="badge bg-danger opacity-75" style="position: absolute; bottom: 5px; left: 5px; font-size: 10px;">LIVE</div>
                        </div>
                        <ul class="list-group list-group-flush">

                            <li class="list-group-item">
                                🟢 Camera Connected
                            </li>

                            <li class="list-group-item">
                                🟢 Screen Monitoring
                            </li>

                            <li class="list-group-item">
                                🟢 Clipboard Protected
                            </li>

                            <li class="list-group-item">
                                🟢 Anti Cheat Active
                            </li>

                        </ul>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script>

                let seconds = 1800;

        setInterval(() => {

        let m = Math.floor(seconds / 60);

        let s = seconds % 60;

        document.getElementById("timer").innerHTML =
        `${m}:${s<10?'0':''}${s}`;

        seconds--;

        },1000);

        const sessionId = document.getElementById("exam-session-id").value;
        let isSubmitting = false;

        // Clear active selection choice from radio arrays
        function clearSelection(radioName) {
            document.querySelectorAll(`input[name='${radioName}']`).forEach(radio => {
                radio.checked = false;
            });
        }

        // Centrally processes context anomalies and focus boundary changes
        function syncViolation(type) {
            if (isSubmitting) return;

            fetch(`/api/proctor/log-violation?type=${type}&sessionId=${sessionId}`, { method: 'POST' })
            .then(res => res.json())
            .then(data => {
                if(data.status === "Blocked_By_Violation") {
                    isSubmitting = true;
                    window.location.href = "/Student/Terminated";
                }
            });
        }

        // Force constraints and query hardware stream hooks on component ready configurations
        window.addEventListener('DOMContentLoaded', () => {
            enforceWindowCage();

            if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
                navigator.mediaDevices.getUserMedia({ video: true })
                .then(function (stream) {
                    const videoElement = document.getElementById('proctor-webcam');
                    if (videoElement) { videoElement.srcObject = stream; }
                })
                .catch(function (error) {
                    alert("🚨 Hardware Access Denied: Camera permission is strictly mandatory.");
                    window.close();
                });
            }
        });

        // Snaps display dimensions strictly back to maximum monitor limits
        function enforceWindowCage() {
            if (isSubmitting) return;
            window.moveTo(0, 0);
            window.resizeTo(window.screen.availWidth, window.screen.availHeight);
        }

        // Catch attempts to shrink or split window layouts
        window.addEventListener('resize', () => {
            if (!isSubmitting) {
                syncViolation("TabSwitch");
                enforceWindowCage();
            }
        });

        // Check loop targeting attempts to slide the application frame away from origin coordinate limits
        setInterval(() => {
            if ((window.screenX > 0 || window.screenY > 0) && !isSubmitting) {
                syncViolation("TabSwitch");
                enforceWindowCage();
            }
        }, 500);

        // Capture context shifts to back overlays, secondary apps, or alternative displays
        window.addEventListener('blur', () => {
            syncViolation("TabSwitch");
        });

        // Secondary layer check monitoring native tab index switches
        document.addEventListener('visibilitychange', () => {
            if (document.hidden) { syncViolation("TabSwitch"); }
        });

        // Block native text system copy calls
        document.addEventListener('copy', (e) => e.preventDefault());

        // Disallow external textual pasting across fields
        document.querySelectorAll('.anti-paste-field').forEach(el => {
            el.addEventListener('paste', (e) => e.preventDefault());
        });

        // Safely submits data layout strings and closes popup window cleanly
        function handleFormSubmit(event) {
            event.preventDefault();
            isSubmitting = true;

            const form = document.getElementById("examForm");
            const formData = new FormData(form);

            document.getElementById("progressBar").style.width="100%";

            fetch(form.action, {
                method: 'POST',
                body: formData
            }).then(response => {
                window.close();
            }).catch(err => {
                alert("Network connection error encountered during sheet serialization.");
                isSubmitting = false;
            });
        }

                function selectOption(card) {

            const parent = card.parentElement;

            parent.querySelectorAll(".option-card").forEach(x => {
                x.classList.remove("selected-option");
            });

            card.classList.add("selected-option");

            card.querySelector("input").checked = true;
        }
    </script>
</body>
</html>